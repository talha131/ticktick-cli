# macOS
.DS_Store

# Defensive: secrets, tokens, and the SQLite cache live at
# $XDG_CONFIG_HOME/ticktick-cli/ (default ~/.config/ticktick-cli/) by
# design — outside this repo. These entries protect against accidental
# co-location (symlinks, future refactors, etc.).
.ticktick-auth
*.ticktick-auth
secrets.env
cache/
